APP_ENV=development

#Postgres
POSTGRES_DB=prism
POSTGRES_USER=prism_user
POSTGRES_PASSWORD=prism_password
POSTGRES_PORT=5432

#Redis
REDIS_PASSWORD=12345abcde
REDIS_HOST=localhost
REDIS_PORT=6379

#Kafka
KAFKA_BOOTSTRAP_SERVER_HOST=localhost
KAFKA_BOOTSTRAP_SERVER_PORT=9092
KAFKA_CACHE_INVALIDATIONS_TOPIC=assignment-cache-invalidations
KAFKA_EVENTS_TOPIC=events

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_password
CLICKHOUSE_DB=default


# Global
BUCKET_COUNT=10000
SALT_VALUE=ULTRA_SECRET_SALT

# Experimentation Service
EXPERIMENTATION_SERVICE_GRPC_SERVER_ADDRESS=localhost
EXPERIMENTATION_SERVICE_GRPC_SERVER_PORT=50052
EXPERIMENTATION_SERVICE_HTTP_PORT=8081
EXPERIMENTATION_SERVICE_LOG_LEVEL=info
EXPERIMENTATION_SERVICE_LOG_FORMAT=text


# Assignment Service
ASSIGNMENT_SERVICE_HTTP_PORT=8082
ASSIGNMENT_SERVICE_KAFKA_CONSUMER_GROUP_ID=assignment_service_group
ASSIGNMENT_SERVICE_GRPC_SERVER_ADDRESS=localhost
ASSIGNMENT_SERVICE_GRPC_SERVER_PORT=50053
ASSIGNMENT_SERVICE_CACHE_ENABLED=true
ASSIGNMENT_SERVICE_LOG_LEVEL=info
ASSIGNMENT_SERVICE_LOG_FORMAT=text

# Events Service
EVENTS_SERVICE_SERVER_HOST=localhost
EVENTS_SERVICE_SERVER_PORT=5678


# Clickhouse writer
CLICKHOUSE_WRITER_MICROBATCH_SIZE=10000
CLICKHOUSE_WRITER_KAFKA_CONSUMER_GROUP_ID=clickhouse_writer_group
CLICKHOUSE_WRITER_LOG_LEVEL=info
CLICKHOUSE_WRITER_LOG_FORMAT=text

# Data Cooking Service
DATA_COOKING_SERVICE_KAFKA_CONSUMER_GROUP_ID=data_cooking_service_group
DATA_COOKING_SERVICE_MICROBATCH_SIZE=10000
DATA_COOKING_SERVICE_MICROBATCH_FLUSH_TIMEOUT_SECONDS=6000
DATA_COOKING_SERVICE_LOG_LEVEL=info
DATA_COOKING_SERVICE_LOG_FORMAT=text

## Stats Engine
STATS_ENGINE_GRPC_SERVER_ADDRESS=localhost
STATS_ENGINE_GRPC_SERVER_PORT=50054

# Caddy
PRISM_PUBLIC_HOSTNAME=localhost
CADDY_CERT_DIR=../../infrastructure/caddy/certs
CADDY_TLS_CERT_PATH=/certs/tls.crt
CADDY_TLS_KEY_PATH=/certs/tls.key


